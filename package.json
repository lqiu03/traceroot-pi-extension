{
  "name": "@traceroot-ai/pi-extension",
  "version": "0.1.0",
  "description": "Traceroot extension for pi. Automatic OpenTelemetry tracing of pi sessions, turns, LLM calls, and tool executions to Traceroot.",
  "keywords": [
    "traceroot",
    "llm",
    "observability",
    "opentelemetry",
    "pi",
    "pi-package",
    "tracing"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/traceroot-ai/traceroot-pi-extension.git"
  },
  "homepage": "https://traceroot.ai",
  "bugs": {
    "url": "https://github.com/traceroot-ai/traceroot-pi-extension/issues"
  },
  "type": "module",
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/test-support.ts",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test src/*.test.ts src/handlers/*.test.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sync:version": "node scripts/sync-version.mjs",
    "check": "node scripts/sync-version.mjs --check && tsc --noEmit && node --test src/*.test.ts src/handlers/*.test.ts",
    "prepack": "node scripts/sync-version.mjs --check"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.57.2",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.79.0 <1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "pnpm@10.14.0"
}
